# Domain Configuration
VITE_DASHBOARD_DOMAIN=dashboard.example.com
VITE_API_DOMAIN=api.example.com
CORS_ORIGIN=https://dashboard.example.com
NODE_ENV=production

# Container Resource Limits (match your server/LXC allocation)
# Run `nproc` and `free -h` to check your actual values
CONTAINER_CORES=2
CONTAINER_RAM_GB=8

# Security (Optional)
TERMINAL_USER=ubuntu
